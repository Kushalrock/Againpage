# Copy to `engine/.env` and fill in. The API + worker load this on startup.
# A real environment variable (exported in your shell) always overrides these.
# `.env` is git-ignored; `.env.example` is committed.

# OpenRouter API key — needed for any openrouter/* model (summariser, writer).
OPENROUTER_API_KEY=sk-or-...

# Only if your Ollama endpoint requires auth (local Ollama does not).
# OLLAMA_API_KEY=

# Postgres DSN — defaults to the docker-compose DB, override only if different.
# DATABASE_URL=postgresql://postgres:dev@localhost:5432/againpage

# API port (default 8000).
# AGAINPAGE_API_PORT=8000
