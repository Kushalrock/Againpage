  "scripts": {
    "db:up": "docker compose -f infra/docker-compose.yaml up -d",
    "db:down": "docker compose -f infra/docker-compose.yaml down",
    "db:reset": "cd engine && uv run python scripts/reset_db.py",
    "dev": "pnpm db:up && pnpm --filter desktop tauri dev",
    "build:desktop": "pnpm --filter desktop tauri build",
    "engine:up": "docker compose up --build -d",
    "engine:logs": "docker compose logs -f",
    "engine:down": "docker compose down"
  },
