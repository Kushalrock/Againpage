# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# externalBin sidecars (engine/scripts/build_engine.sh output, per M6 T1) and
# bundled Postgres (per M6 T3) are produced by the build pipeline, not committed.
# Placeholder .gitkeep files keep the dirs present so `cargo build` (generate_context!)
# can resolve bundle.externalBin/resources paths before real artifacts exist.
/binaries/*
!/binaries/.gitkeep
/resources/postgres/*
!/resources/postgres/.gitkeep
