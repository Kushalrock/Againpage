{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Againpage",
  "mainBinaryName": "Againpage",
  "version": "0.1.1",
  "identifier": "com.agrkushal.againpage",
  "build": {
    "beforeDevCommand": "pnpm --filter reader dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter reader build",
    "frontendDist": "../../reader/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Againpage",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "certificateThumbprint": null
    }
  }
}